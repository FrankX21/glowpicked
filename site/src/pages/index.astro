---

<Layout
  title="GlowPicked - AI-Powered Beauty Intelligence"
  description="AI ingredient analysis meets real skincare expertise. Top 3 budget and luxury picks in every beauty category, backed by science."
  keywords="AI skincare analysis, ingredient analysis, beauty product reviews, budget skincare, luxury skincare, GlowScore"
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <h1 class="hero-title">
            We Don't Count Stars.
            <span class="gradient-text">We Read the Science.</span>
          </h1>
          <p class="hero-description">
            AI-powered ingredient analysis meets real customer insights. We break down every formula to find what actually works — for every budget.
          </p>
          <div class="hero-stats">
            <div class="stat">
              <span class="stat-number">Top 3</span>
              <span class="stat-label">Budget Under $30</span>
            </div>
            <div class="stat">
              <span class="stat-number">Top 3</span>
              <span class="stat-label">Luxury Over $50</span>
            </div>
            <div class="stat">
              <span class="stat-number">10</span>
              <span class="stat-label">Categories</span>
            </div>
          </div>
          <div class="hero-cta">
            <a href="/reviews/" class="btn-primary">Explore Categories</a>
            <a href="/about" class="btn-secondary">How GlowScore Works</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Articles -->
  <section id="featured" class="featured-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Featured Categories</h2>
        <p class="section-subtitle">AI ingredient analysis + real customer insights</p>
      </div>
      <div class="articles-grid">
        {featuredArticles.map((article) => (
          <article class="article-card">
            <div class="article-image">
              <img src={article.image} alt={article.title} width="400" height="250" loading="lazy" />
              <div class="article-category">{article.category}</div>
              <div class="article-rating">
                <span class="rating-text">{article.badge}</span>
              </div>
            </div>
            <div class="article-content">
              <h3 class="article-title">
                <a href={article.url}>{article.title}</a>
              </h3>
              <p class="article-description">{article.description}</p>
              <a href={article.url} class="article-link">See Our Picks →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="categories-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">All Categories</h2>
        <p class="section-subtitle">Top picks in every category</p>
      </div>
      <div class="categories-grid">
        {categories.map((category) => (
          <a href={category.url} class="category-card">
            <div class="category-icon">{category.icon}</div>
            <h3 class="category-name">{category.name}</h3>
            <p class="category-description">{category.description}</p>
            <span class="category-count">{category.tag}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How GlowScore Works -->
  <section class="glowscore-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">How GlowScore Works</h2>
        <p class="section-subtitle">Our AI-powered methodology in 3 steps</p>
      </div>
      <div class="glowscore-steps">
        <div class="step">
          <div class="step-number">1</div>
          <h3>Ingredient Analysis</h3>
          <p>Our AI breaks down every formula — active ingredients, concentrations, and their known effects based on established cosmetic science.</p>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <h3>Customer Insights</h3>
          <p>We analyze hundreds of real customer experiences to identify what works, for whom, and what to watch out for.</p>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <h3>GlowScore Rating</h3>
          <p>Our proprietary score combines ingredient science, customer satisfaction, safety profile, and value — all on a clear /100 scale.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Section -->
  <section class="trust-section">
    <div class="container">
      <div class="trust-content">
        <p class="trust-text">
          <strong>Zero Bias:</strong> No sponsored rankings. No paid placements. Just science and real customer experiences.
          Every product is evaluated by our AI on ingredients, safety, and value — the same way for every brand.
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero */
  .hero {
    background: linear-gradient(135deg, #fff5f7 0%, #fce4ec 50%, #f8bbd0 100%);
    padding: 5rem 0 4rem;
  }
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .hero-text {
    max-width: 750px;
  }
  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    color: #1a1a2e;
    font-family: 'Playfair Display', Georgia, serif;
  }
  .gradient-text {
    background: linear-gradient(135deg, #e91e63, #9c27b0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-description {
    font-size: 1.25rem;
    color: #555;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  .hero-stats {
    display: flex;
    gap: 2rem;
    margin-bottom: 2rem;
    justify-content: center;
  }
  .stat {
    display: flex;
    flex-direction: column;
  }
  .stat-number {
    font-size: 1.3rem;
    font-weight: 700;
    color: #e91e63;
  }
  .stat-label {
    font-size: 0.85rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }
  .btn-primary {
    background: linear-gradient(135deg, #e91e63, #c2185b);
    color: white;
    padding: 0.9rem 2rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.05rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(233,30,99,0.35);
  }
  .btn-secondary {
    background: white;
    color: #e91e63;
    padding: 0.9rem 2rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.05rem;
    border: 2px solid #e91e63;
    transition: all 0.2s;
  }
  .btn-secondary:hover {
    background: #fce4ec;
  }
  .hero-image {
    flex: 0 0 auto;
    position: relative;
  }
  .hero-image img {
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.12);
    width: 100%;
    max-width: 500px;
    height: auto;
  }
  .hero-badge {
    position: absolute;
    bottom: -15px;
    left: 50%;
    transform: translateX(-50%);
    background: white;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
  }

  /* Featured Articles */
  .featured-section {
    padding: 5rem 0;
    background: white;
  }
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .section-title {
    font-size: 2.2rem;
    font-weight: 700;
    color: #1a1a2e;
    font-family: 'Playfair Display', Georgia, serif;
    margin-bottom: 0.5rem;
  }
  .section-subtitle {
    color: #888;
    font-size: 1.1rem;
  }
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .article-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .article-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 35px rgba(0,0,0,0.12);
  }
  .article-image {
    position: relative;
    height: 200px;
    background: linear-gradient(135deg, #fce4ec, #f8bbd0);
    overflow: hidden;
  }
  .article-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .article-category {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(233,30,99,0.9);
    color: white;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }
  .article-rating {
    position: absolute;
    top: 12px;
    right: 12px;
    background: white;
    padding: 0.3rem 0.7rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .article-content {
    padding: 1.5rem;
  }
  .article-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }
  .article-title a {
    color: #1a1a2e;
    text-decoration: none;
  }
  .article-title a:hover {
    color: #e91e63;
  }
  .article-description {
    color: #666;
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 1rem;
  }
  .article-link {
    color: #e91e63;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .article-link:hover {
    text-decoration: underline;
  }

  /* Categories */
  .categories-section {
    padding: 5rem 0;
    background: #fafafa;
  }
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.5rem;
  }
  .category-card {
    background: white;
    border-radius: 16px;
    padding: 2rem 1.5rem;
    text-align: center;
    text-decoration: none;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.2s, box-shadow 0.2s;
    border: 2px solid transparent;
  }
  .category-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(233,30,99,0.15);
    border-color: #f8bbd0;
  }
  .category-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .category-name {
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 0.4rem;
  }
  .category-description {
    font-size: 0.85rem;
    color: #888;
    margin-bottom: 0.5rem;
  }
  .category-count {
    font-size: 0.8rem;
    color: #e91e63;
    font-weight: 600;
  }

  /* GlowScore Steps */
  .glowscore-section {
    padding: 5rem 0;
    background: white;
  }
  .glowscore-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .step {
    text-align: center;
    padding: 2rem 1.5rem;
  }
  .step-number {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e91e63, #9c27b0);
    color: white;
    font-size: 1.4rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }
  .step h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 0.75rem;
    font-family: 'Playfair Display', Georgia, serif;
  }
  .step p {
    font-size: 0.95rem;
    color: #666;
    line-height: 1.6;
  }

  /* Trust */
  .trust-section {
    padding: 3rem 0;
    background: linear-gradient(135deg, #fce4ec, #f3e5f5);
  }
  .trust-text {
    text-align: center;
    font-size: 1.1rem;
    color: #555;
    max-width: 700px;
    margin: 0 auto;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .categories-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 768px) {
    .hero-content {
      flex-direction: column;
      text-align: center;
    }
    .hero-title {
      font-size: 2.2rem;
    }
    .hero-stats {
      justify-content: center;
    }
    .hero-cta {
      justify-content: center;
      flex-wrap: wrap;
    }
    .articles-grid {
      grid-template-columns: 1fr;
    }
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .glowscore-steps {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .container {
      padding: 0 1rem;
    }
  }
</style><!-- Force rebuild Tue Feb 17 14:56:07 EST 2026 -->
